def validate_pan_ai(pan):
    """AI-generated version — pasted verbatim from Claude output."""

    # PAN must be exactly 10 characters
    if len(pan) != 10:
        return False, "PAN must be exactly 10 characters"

    # First 5 characters must be uppercase letters
    for i in range(5):
        if not pan[i].isalpha() or not pan[i].isupper():
            return False, f"Position {i+1} must be an uppercase letter"

    # Characters 6-9 must be digits
    for i in range(5, 9):
        if not pan[i].isdigit():
            return False, f"Position {i+1} must be a digit"

    # Last character must be an uppercase letter
    if not pan[9].isalpha() or not pan[9].isupper():
        return False, "Position 10 must be an uppercase letter"

    # 4th character indicates taxpayer type
    taxpayer_types = {
        'P': 'Individual',
        'C': 'Company',
        'H': 'Hindu Undivided Family',
        'F': 'Firm',
        'A': 'Association of Persons',
        'T': 'Trust',
        'B': 'Body of Individuals',
        'L': 'Local Authority',
        'J': 'Artificial Juridical Person',
        'G': 'Government'
    }

    fourth_char = pan[3]
    if fourth_char in taxpayer_types:
        taxpayer = taxpayer_types[fourth_char]
    else:
        taxpayer = 'Unknown type'

    return True, f"Valid PAN — Taxpayer type: {taxpayer}"


