import re

# Fix: taxpayer map as module-level constant (not rebuilt each call)
TAXPAYER_TYPES = {
    'P': 'Individual (Person)',
    'C': 'Company',
    'H': 'Hindu Undivided Family (HUF)',
    'F': 'Firm / LLP',
    'A': 'Association of Persons (AOP)',
    'T': 'Trust / AOP (Trusts)',
    'B': 'Body of Individuals (BOI)',
    'L': 'Local Authority',
    'J': 'Artificial Juridical Person',
    'G': 'Government Entity',
}

# Fix: regex expresses the full structure rule in one line
PAN_REGEX = re.compile(r'^[A-Z]{5}[0-9]{4}[A-Z]$')


def validate_pan(raw_input) -> tuple[bool, str]:
    """
    Validate an Indian PAN card number.

    Improvements over AI version:
      ① Type guard    — handles None and non-string inputs gracefully
      ② Normalise     — strips whitespace, auto-uppercases input
      ③ Regex check   — fast structural validation in one line,
                         falls through to char-by-char for error detail
      ④ isupper()     — removed redundant isalpha() check
      ⑤ dict.get()    — Pythonic taxpayer lookup replaces if/else
      ⑥ 5th char      — surname/entity initial surfaced in output
      ⑦ __main__ guard — driver code protected

    Returns:
        (True,  success_message)  if valid
        (False, reason_message)   if invalid
    """

    # ① Type guard — reject None and non-strings before any other check
    if raw_input is None or not isinstance(raw_input, str):
        return False, "Invalid input: expected a string"

    # ② Normalise — strip whitespace, convert to uppercase
    pan = raw_input.strip().upper()

    # Fast length check before regex
    if len(pan) != 10:
        return False, f"Length must be 10 characters (got {len(pan)})"

    # ③ Regex structural check — if it fails, give per-position detail
    if not PAN_REGEX.match(pan):
        for i in range(5):              # positions 1-5: uppercase letter
            if not pan[i].isupper():    # ④ isupper() implies alpha
                return False, (
                    f"Position {i+1} must be an uppercase letter "
                    f"(got '{pan[i]}')"
                )
        for i in range(5, 9):           # positions 6-9: digit
            if not pan[i].isdigit():
                return False, (
                    f"Position {i+1} must be a digit "
                    f"(got '{pan[i]}')"
                )
        if not pan[9].isupper():        # position 10: uppercase letter
            return False, (
                f"Position 10 must be an uppercase letter "
                f"(got '{pan[9]}')"
            )

    # ⑤ dict.get() — cleaner than if/else for taxpayer lookup
    taxpayer = TAXPAYER_TYPES.get(pan[3], 'Unrecognised taxpayer code')

    # ⑥ 5th character = first letter of surname / entity name
    return True, (
        f"Valid PAN    : {pan}\n"
        f"Taxpayer type: {taxpayer}  (4th char '{pan[3]}')\n"
        f"Name initial : '{pan[4]}'  (5th char → surname/entity)"
    )


